;; --- ANTIGRAVITY MASTER DEVELOPER SANDBOX v1.2.1 ---
(version 1)
(deny default)

;; Required for system resolution and basic process initialization
(allow mach-lookup (global-name "*"))
(allow sysctl-read)

;; 1. ESSENTIAL PATH VISIBILITY
(allow file-read-metadata 
       (subpath "/var")
       (subpath "/private")
       (subpath "/Users/jhkaisan"))

;; 2. TOOLCHAIN SHIMS & CONFIGS
(allow file-read* (literal "/private/var/db/xcode_select_link")
       (literal "/Users/jhkaisan/.gitconfig"))
(allow file-read* (subpath "/Library/Developer/CommandLineTools")
       (subpath "/Applications/Xcode.app"))

;; 3. LANGUAGE SPECIFIC CACHES & TOOLCHAINS
(allow file-read* file-write* (subpath "/Users/jhkaisan/.rustup")
       (subpath "/Users/jhkaisan/.cargo")
       (subpath "/Users/jhkaisan/.m2"))

(allow file-read* (subpath "/Library/Java/JavaVirtualMachines")
       (subpath "/usr/libexec/java_home")
       (subpath "/usr/share/java"))

(allow file-map-executable)


;; 4. SYSTEM LIBRARIES & DYNAMIC LINKER
(allow file-read* (subpath "/usr/lib")
       (subpath "/usr/share")
       (subpath "/System/Library")
       (subpath "/usr/local/bin")
       (subpath "/opt/homebrew")
       (subpath "/usr/lib/dyld")
       (subpath "/private/etc"))

(allow file-read*)

;; 5. PROCESS EXECUTION
(allow process-fork)
(allow process-info*)
(allow process-exec 
       (subpath "/bin")
       (subpath "/usr/bin")
       (subpath "/usr/sbin")
       (subpath "/usr/libexec")
       (subpath "/Library/Developer/CommandLineTools/usr/bin")
       (subpath "/sbin")
       (subpath "/opt/homebrew/bin")
       (subpath "/usr/local/bin")
       (subpath "/Users/jhkaisan/.cargo/bin"))

;; 6. THE WORKSPACE
(allow file-read* file-write* (subpath "/Users/jhkaisan/repot/antigravity/exalted"))

;; 7. TEMPORARY FILES
(allow file-read* file-write* (subpath "/private/var/folders")
       (subpath "/tmp"))

;; 8. NETWORK ACCESS
(allow network-outbound)

;; Standard device access
(allow file-read-data (literal "/dev/null"))
(allow file-write-data (literal "/dev/null"))

(allow file-read-data (literal "/dev/zero"))
(allow file-read-data (literal "/dev/urandom"))

(allow file-read-metadata (subpath "/var/db"))
