{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exalted 3e Charm Collection",
  "description": "Schema for Exalted 3rd Edition charms used in the Vibethema character builder.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to the schema file."
    },
    "ability": {
      "type": "string",
      "description": "The ability these charms belong to (e.g., Archery, Performance)."
    },
    "exalt": {
      "type": "string",
      "enum": ["solar", "dragon-blooded", "lunar", "sidereal", "abyssal"],
      "default": "solar",
      "description": "The type of Exalt these charms are for."
    },
    "version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Version of the data format."
    },
    "charms": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/charm"
      }
    }
  },
  "required": ["ability", "exalt", "charms", "version"],
  "definitions": {
    "charm": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
          "description": "Deterministic UUID for the charm."
        },
        "name": {
          "type": "string",
          "description": "The charm's name."
        },
        "ability": {
          "type": "string",
          "description": "The ability rating it depends on."
        },
        "minAbility": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "minEssence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          },
          "description": "List of prerequisite charm UUIDs."
        },
        "cost": {
          "type": "string",
          "description": "Activation cost (e.g., '1m', '3m, 1wp', '—')."
        },
        "type": {
          "type": "string",
          "description": "Charm type (e.g., Supplemental, Reflexive, Simple, Permanent)."
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of keywords (empty if None)."
        },
        "duration": {
          "type": "string",
          "description": "The duration of the effect."
        },
        "fullText": {
          "type": "string",
          "description": "The full mechanical effect text."
        },
        "rawData": {
          "type": "string",
          "description": "Original PDF text block."
        },
        "potentiallyProblematicImport": {
          "type": "boolean",
          "description": "Flag for unresolved dependencies or parsing errors."
        }
      },
      "required": [
        "id",
        "name",
        "ability",
        "minAbility",
        "minEssence",
        "prerequisites",
        "cost",
        "type",
        "keywords",
        "duration",
        "fullText",
        "rawData",
        "potentiallyProblematicImport"
      ]
    }
  }
}
